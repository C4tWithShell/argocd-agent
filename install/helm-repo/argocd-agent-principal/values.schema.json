{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "additionalProperties": true,
  "properties": {
    "affinity": {
      "additionalProperties": true,
      "description": "Affinity rules for pod scheduling",
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "automountServiceAccountToken": {
      "default": true,
      "description": "Automount API credentials for the Service Account into the pod.",
      "title": "automountServiceAccountToken",
      "type": "boolean"
    },
    "deploymentAnnotations": {
      "additionalProperties": true,
      "description": "Annotations for the Deployment",
      "required": [],
      "title": "deploymentAnnotations",
      "type": "object"
    },
    "extraEnv": {
      "description": "# -- Extra environment variables to add to the container",
      "items": {
        "required": []
      },
      "title": "extraEnv",
      "type": "array"
    },
    "extraVolumeMounts": {
      "description": "# -- Extra volume mounts",
      "items": {
        "required": []
      },
      "title": "extraVolumeMounts",
      "type": "array"
    },
    "extraVolumes": {
      "description": "# -- Extra volumes",
      "items": {
        "required": []
      },
      "title": "extraVolumes",
      "type": "array"
    },
    "fullnameOverride": {
      "default": "",
      "description": "Override the full resource name",
      "title": "fullnameOverride",
      "type": "string"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "description": "#",
      "properties": {
        "pullPolicy": {
          "default": "Always",
          "description": "Image pull policy",
          "title": "pullPolicy",
          "type": "string"
        },
        "repository": {
          "default": "ghcr.io/argoproj-labs/argocd-agent/argocd-agent",
          "description": "Image repository",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "latest",
          "description": "Image tag",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [
        "repository",
        "pullPolicy",
        "tag"
      ],
      "title": "image",
      "type": "object"
    },
    "imagePullSecrets": {
      "description": "Image pull secrets",
      "items": {
        "required": []
      },
      "title": "imagePullSecrets",
      "type": "array"
    },
    "ingress": {
      "additionalProperties": false,
      "description": "#",
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "required": [],
          "title": "annotations",
          "type": "object"
        },
        "className": {
          "default": "",
          "title": "className",
          "type": "string"
        },
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "hosts": {
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "host": {
                    "default": "argocd-agent-principal.example.com",
                    "title": "host",
                    "type": "string"
                  },
                  "paths": {
                    "items": {
                      "anyOf": [
                        {
                          "additionalProperties": false,
                          "properties": {
                            "path": {
                              "default": "/",
                              "title": "path",
                              "type": "string"
                            },
                            "pathType": {
                              "default": "Prefix",
                              "title": "pathType",
                              "type": "string"
                            }
                          },
                          "required": [
                            "path",
                            "pathType"
                          ],
                          "type": "object"
                        }
                      ],
                      "required": []
                    },
                    "title": "paths",
                    "type": "array"
                  }
                },
                "required": [
                  "host",
                  "paths"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "hosts",
          "type": "array"
        },
        "tls": {
          "items": {
            "required": []
          },
          "title": "tls",
          "type": "array"
        }
      },
      "required": [
        "enabled",
        "className",
        "annotations",
        "hosts",
        "tls"
      ],
      "title": "ingress",
      "type": "object"
    },
    "nameOverride": {
      "default": "",
      "description": "Override the chart name",
      "title": "nameOverride",
      "type": "string"
    },
    "namespaceOverride": {
      "default": "",
      "description": "#\nOverride namespace to deploy the agent into. Leave empty to use the release namespace.",
      "title": "namespaceOverride",
      "type": "string"
    },
    "networkPolicy": {
      "additionalProperties": true,
      "description": "#",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Whether to create a NetworkPolicy for the principal",
          "title": "enabled",
          "type": "boolean"
        },
        "monitoringNamespace": {
          "default": "monitoring",
          "description": "Namespace label value for monitoring namespace (used for metrics/healthz ingress)",
          "title": "monitoringNamespace",
          "type": "string"
        },
        "grpcIngress": {
          "additionalProperties": true,
          "description": "Ingress peers allowed to reach the gRPC port (8443). Empty from[] = any source.",
          "properties": {
            "from": {
              "items": { "required": [] },
              "type": "array"
            }
          },
          "type": "object"
        },
        "redisProxyIngress": {
          "additionalProperties": true,
          "description": "Ingress peers allowed to reach the Redis proxy port (6379).",
          "properties": {
            "from": {
              "items": { "required": [] },
              "type": "array"
            }
          },
          "type": "object"
        },
        "resourceProxyIngress": {
          "additionalProperties": true,
          "description": "Ingress peers allowed to reach the Resource proxy port (9090).",
          "properties": {
            "from": {
              "items": { "required": [] },
              "type": "array"
            }
          },
          "type": "object"
        },
        "extraIngress": {
          "description": "Additional ingress rules appended to the generated policy",
          "items": { "required": [] },
          "type": "array"
        },
        "egress": {
          "description": "Egress rules. Non-empty adds 'Egress' to policyTypes.",
          "items": { "required": [] },
          "type": "array"
        },
        "customIngressRules": {
          "description": "Fully replace generated ingress rules with this custom list.",
          "items": { "required": [] },
          "type": "array"
        },
        "extraPolicies": {
          "additionalProperties": true,
          "description": "Map of extra NetworkPolicy specs keyed by name suffix.",
          "type": "object"
        }
      },
      "required": [
        "enabled",
        "monitoringNamespace"
      ],
      "title": "networkPolicy",
      "type": "object"
    },
    "nodeSelector": {
      "additionalProperties": true,
      "description": "#\nNode selector for scheduling the agent Pod.",
      "required": [],
      "title": "nodeSelector",
      "type": "object"
    },
    "params": {
      "additionalProperties": true,
      "description": "#",
      "properties": {
        "allowedNamespaces": {
          "default": "",
          "description": "Comma-separated list of namespaces to watch (supports shell-style wildcards)",
          "title": "allowedNamespaces",
          "type": "string"
        },
        "auth": {
          "default": "mtls:CN=([^,]+)",
          "description": "Authentication method. Format: \u003cmethod\u003e:\u003cconfig\u003e\nExamples:\n  \"mtls:CN=([^,]+)\"\n  \"userpass:/app/config/userpass/passwd\"\n  \"header:x-forwarded-client-cert:^.*URI=spiffe://[^/]+/ns/[^/]+/sa/([^,;]+)\"",
          "title": "auth",
          "type": "string"
        },
        "destinationBasedMapping": {
          "default": "false",
          "description": "Use destination-based mapping (route apps to agents via spec.destination.name)",
          "title": "destinationBasedMapping",
          "type": "string"
        },
        "eventProcessors": {
          "default": "10",
          "description": "Number of concurrent event processors",
          "title": "eventProcessors",
          "type": "string"
        },
        "healthzPort": {
          "default": "8003",
          "description": "Health check server port",
          "title": "healthzPort",
          "type": "string"
        },
        "jwt": {
          "additionalProperties": false,
          "properties": {
            "allowGenerate": {
              "default": "false",
              "description": "Allow the principal to auto-generate JWT signing key (dev only)",
              "title": "allowGenerate",
              "type": "string"
            },
            "keyPath": {
              "default": "",
              "description": "Path to the JWT signing key (overrides secretName if set)",
              "title": "keyPath",
              "type": "string"
            },
            "secretName": {
              "default": "argocd-agent-jwt",
              "description": "Name of the secret containing the JWT signing key",
              "title": "secretName",
              "type": "string"
            }
          },
          "required": [
            "allowGenerate",
            "secretName",
            "keyPath"
          ],
          "title": "jwt",
          "type": "object"
        },
        "keepAliveMinInterval": {
          "default": "0",
          "description": "Drop agent connections that send keepalive pings more often than this interval",
          "title": "keepAliveMinInterval",
          "type": "string"
        },
        "labelSelector": {
          "default": "",
          "description": "Kubernetes label selector to restrict which resources the principal watches.\nUsed in hybrid architectures where a traditional app-controller coexists with the principal.",
          "title": "labelSelector",
          "type": "string"
        },
        "listenHost": {
          "default": "",
          "description": "Interface address to listen on. Empty = all interfaces.",
          "title": "listenHost",
          "type": "string"
        },
        "listenPort": {
          "default": "8443",
          "description": "gRPC server listen port",
          "title": "listenPort",
          "type": "string"
        },
        "logFormat": {
          "default": "text",
          "description": "Log format: text or json",
          "title": "logFormat",
          "type": "string"
        },
        "logLevel": {
          "default": "info",
          "description": "Log level: trace, debug, info, warn, error",
          "title": "logLevel",
          "type": "string"
        },
        "metricsPort": {
          "default": "8000",
          "description": "Metrics server port",
          "title": "metricsPort",
          "type": "string"
        },
        "namespace": {
          "default": "argocd",
          "description": "Namespace the principal operates in",
          "title": "namespace",
          "type": "string"
        },
        "namespaceCreate": {
          "additionalProperties": false,
          "properties": {
            "enable": {
              "default": "false",
              "description": "Allow the principal to create namespaces for agents",
              "title": "enable",
              "type": "string"
            },
            "labels": {
              "default": "",
              "description": "Labels to apply to created namespaces (comma-separated key=value pairs)",
              "title": "labels",
              "type": "string"
            },
            "pattern": {
              "default": "",
              "description": "Regexp to restrict names of created namespaces",
              "title": "pattern",
              "type": "string"
            }
          },
          "required": [
            "enable",
            "pattern",
            "labels"
          ],
          "title": "namespaceCreate",
          "type": "object"
        },
        "pprofPort": {
          "default": "0",
          "description": "Port for pprof server (0 = disabled)",
          "title": "pprofPort",
          "type": "string"
        },
        "redis": {
          "additionalProperties": true,
          "properties": {
            "caPath": {
              "default": "/app/config/redis-tls/ca.crt",
              "description": "Path to CA certificate for verifying Redis TLS certificate",
              "title": "caPath",
              "type": "string"
            },
            "caSecretName": {
              "default": "argocd-redis-tls",
              "description": "Secret name containing CA certificate for verifying Redis TLS certificate",
              "title": "caSecretName",
              "type": "string"
            },
            "compressionType": {
              "default": "gzip",
              "description": "Compression type for Redis connection",
              "title": "compressionType",
              "type": "string"
            },
            "proxyServerTls": {
              "additionalProperties": false,
              "properties": {
                "certPath": {
                  "default": "/app/config/redis-proxy-server-tls/tls.crt",
                  "description": "Path to TLS certificate for Redis proxy server",
                  "title": "certPath",
                  "type": "string"
                },
                "keyPath": {
                  "default": "/app/config/redis-proxy-server-tls/tls.key",
                  "description": "Path to TLS private key for Redis proxy server",
                  "title": "keyPath",
                  "type": "string"
                },
                "secretName": {
                  "default": "argocd-redis-proxy-tls",
                  "description": "Secret name containing TLS certificate and key for Redis proxy server",
                  "title": "secretName",
                  "type": "string"
                }
              },
              "required": [
                "certPath",
                "keyPath",
                "secretName"
              ],
              "title": "proxyServerTls",
              "type": "object"
            },
            "serverAddress": {
              "default": "argocd-redis:6379",
              "description": "Redis server address",
              "title": "serverAddress",
              "type": "string"
            },
            "tls": {
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "default": "false",
                  "description": "Enable TLS for Redis connections",
                  "title": "enabled",
                  "type": "string"
                },
                "insecure": {
                  "default": "false",
                  "description": "Skip verification of Redis TLS certificate (INSECURE - for development only)",
                  "title": "insecure",
                  "type": "string"
                }
              },
              "required": [
                "enabled",
                "insecure"
              ],
              "title": "tls",
              "type": "object"
            }
          },
          "required": [
            "serverAddress",
            "compressionType",
            "tls",
            "proxyServerTls",
            "caPath",
            "caSecretName"
          ],
          "title": "redis",
          "type": "object"
        },
        "resourceProxy": {
          "additionalProperties": false,
          "properties": {
            "caPath": {
              "default": "",
              "description": "Path to the resource proxy CA cert",
              "title": "caPath",
              "type": "string"
            },
            "caSecretName": {
              "default": "argocd-agent-ca",
              "description": "Name of the secret containing the resource proxy CA cert",
              "title": "caSecretName",
              "type": "string"
            },
            "enable": {
              "default": "true",
              "description": "Enable the resource proxy",
              "title": "enable",
              "type": "string"
            },
            "secretName": {
              "default": "argocd-agent-resource-proxy-tls",
              "description": "Name of the secret containing the resource proxy TLS cert/key",
              "title": "secretName",
              "type": "string"
            },
            "tlsCertPath": {
              "default": "",
              "description": "Path to the resource proxy TLS cert",
              "title": "tlsCertPath",
              "type": "string"
            },
            "tlsKeyPath": {
              "default": "",
              "description": "Path to the resource proxy TLS key",
              "title": "tlsKeyPath",
              "type": "string"
            }
          },
          "required": [
            "enable",
            "secretName",
            "tlsCertPath",
            "tlsKeyPath",
            "caSecretName",
            "caPath"
          ],
          "title": "resourceProxy",
          "type": "object"
        },
        "tls": {
          "additionalProperties": false,
          "properties": {
            "allowGenerate": {
              "default": "false",
              "description": "Allow the principal to auto-generate TLS cert/key (dev only)",
              "title": "allowGenerate",
              "type": "string"
            },
            "ciphersuites": {
              "default": "",
              "description": "Comma-separated list of TLS cipher suites (empty = Go defaults)",
              "title": "ciphersuites",
              "type": "string"
            },
            "clientCertMatchSubject": {
              "default": "false",
              "description": "Match client cert subject to agent name",
              "title": "clientCertMatchSubject",
              "type": "string"
            },
            "clientCertRequire": {
              "default": "false",
              "description": "Require client certificates from agents",
              "title": "clientCertRequire",
              "type": "string"
            },
            "insecurePlaintext": {
              "default": "false",
              "description": "Run gRPC without TLS (for service mesh / mTLS sidecar environments)",
              "title": "insecurePlaintext",
              "type": "string"
            },
            "maxVersion": {
              "default": "",
              "description": "Maximum TLS version (empty = use highest available)",
              "title": "maxVersion",
              "type": "string"
            },
            "minVersion": {
              "default": "tls1.3",
              "description": "Minimum TLS version: tls1.1, tls1.2, tls1.3",
              "title": "minVersion",
              "type": "string"
            },
            "rootCaPath": {
              "default": "",
              "description": "Path to the root CA certificate (overrides rootCaSecretName if set)",
              "title": "rootCaPath",
              "type": "string"
            },
            "rootCaSecretName": {
              "default": "argocd-agent-ca",
              "description": "Name of the secret containing the root CA certificate",
              "title": "rootCaSecretName",
              "type": "string"
            },
            "secretName": {
              "default": "argocd-agent-principal-tls",
              "description": "Name of the secret containing the TLS cert and key",
              "title": "secretName",
              "type": "string"
            },
            "serverCertPath": {
              "default": "",
              "description": "Path to the TLS certificate (overrides secretName if set)",
              "title": "serverCertPath",
              "type": "string"
            },
            "serverKeyPath": {
              "default": "",
              "description": "Path to the TLS private key (overrides secretName if set)",
              "title": "serverKeyPath",
              "type": "string"
            }
          },
          "required": [
            "secretName",
            "serverCertPath",
            "serverKeyPath",
            "allowGenerate",
            "insecurePlaintext",
            "clientCertRequire",
            "rootCaSecretName",
            "rootCaPath",
            "clientCertMatchSubject",
            "minVersion",
            "maxVersion",
            "ciphersuites"
          ],
          "title": "tls",
          "type": "object"
        },
        "websocketEnable": {
          "default": "false",
          "description": "Enable WebSocket for streaming events to agents",
          "title": "websocketEnable",
          "type": "string"
        }
      },
      "required": [
        "listenHost",
        "listenPort",
        "logLevel",
        "logFormat",
        "metricsPort",
        "healthzPort",
        "namespace",
        "allowedNamespaces",
        "namespaceCreate",
        "tls",
        "jwt",
        "auth",
        "resourceProxy",
        "redis",
        "websocketEnable",
        "keepAliveMinInterval",
        "pprofPort",
        "destinationBasedMapping",
        "labelSelector",
        "eventProcessors"
      ],
      "title": "params",
      "type": "object"
    },
    "podAnnotations": {
      "additionalProperties": true,
      "description": "Annotations for the Pod",
      "required": [],
      "title": "podAnnotations",
      "type": "object"
    },
    "podDisruptionBudget": {
      "additionalProperties": false,
      "description": "#",
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "minAvailable": {
          "default": 1,
          "title": "minAvailable",
          "type": "integer"
        }
      },
      "required": [
        "enabled",
        "minAvailable"
      ],
      "title": "podDisruptionBudget",
      "type": "object"
    },
    "podLabels": {
      "additionalProperties": true,
      "description": "Additional labels to add to the agent Pod.",
      "required": [],
      "title": "podLabels",
      "type": "object"
    },
    "podSecurityContext": {
      "additionalProperties": true,
      "description": "#",
      "properties": {
        "fsGroup": {
          "default": 999,
          "title": "fsGroup",
          "type": "integer"
        },
        "fsGroupChangePolicy": {
          "default": "OnRootMismatch",
          "title": "fsGroupChangePolicy",
          "type": "string"
        },
        "runAsGroup": {
          "default": 999,
          "title": "runAsGroup",
          "type": "integer"
        },
        "runAsNonRoot": {
          "default": true,
          "title": "runAsNonRoot",
          "type": "boolean"
        },
        "runAsUser": {
          "default": 999,
          "title": "runAsUser",
          "type": "integer"
        },
        "seccompProfile": {
          "additionalProperties": false,
          "properties": {
            "type": {
              "default": "RuntimeDefault",
              "title": "type",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "seccompProfile",
          "type": "object"
        }
      },
      "required": [
        "fsGroup",
        "fsGroupChangePolicy",
        "runAsGroup",
        "runAsNonRoot",
        "runAsUser",
        "seccompProfile"
      ],
      "title": "podSecurityContext",
      "type": "object"
    },
    "priorityClassName": {
      "default": "",
      "description": "PriorityClassName for the agent Pod.",
      "title": "priorityClassName",
      "type": "string"
    },
    "probes": {
      "additionalProperties": false,
      "description": "#\nLiveness and readiness probe configuration.",
      "properties": {
        "liveness": {
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "default": true,
              "description": "Enable the liveness probe.",
              "title": "enabled",
              "type": "boolean"
            },
            "failureThreshold": {
              "default": 3,
              "description": "Failure threshold for liveness probe.",
              "title": "failureThreshold",
              "type": "integer"
            },
            "httpGet": {
              "additionalProperties": false,
              "properties": {
                "path": {
                  "default": "/healthz",
                  "title": "path",
                  "type": "string"
                },
                "port": {
                  "default": "healthz",
                  "title": "port",
                  "type": "string"
                }
              },
              "required": [
                "path",
                "port"
              ],
              "title": "httpGet",
              "type": "object"
            },
            "initialDelaySeconds": {
              "default": 10,
              "description": "Initial delay before the first liveness probe.",
              "title": "initialDelaySeconds",
              "type": "integer"
            },
            "periodSeconds": {
              "default": 10,
              "description": "Frequency of liveness probes.",
              "title": "periodSeconds",
              "type": "integer"
            },
            "timeoutSeconds": {
              "default": 2,
              "description": "Timeout for liveness probe.",
              "title": "timeoutSeconds",
              "type": "integer"
            }
          },
          "required": [
            "enabled",
            "httpGet",
            "initialDelaySeconds",
            "periodSeconds",
            "timeoutSeconds",
            "failureThreshold"
          ],
          "title": "liveness",
          "type": "object"
        },
        "readiness": {
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "default": true,
              "description": "Enable the readiness probe.",
              "title": "enabled",
              "type": "boolean"
            },
            "failureThreshold": {
              "default": 3,
              "description": "Failure threshold for readiness probe.",
              "title": "failureThreshold",
              "type": "integer"
            },
            "httpGet": {
              "additionalProperties": false,
              "properties": {
                "path": {
                  "default": "/healthz",
                  "title": "path",
                  "type": "string"
                },
                "port": {
                  "default": "healthz",
                  "title": "port",
                  "type": "string"
                }
              },
              "required": [
                "path",
                "port"
              ],
              "title": "httpGet",
              "type": "object"
            },
            "initialDelaySeconds": {
              "default": 5,
              "description": "Initial delay before the first readiness probe.",
              "title": "initialDelaySeconds",
              "type": "integer"
            },
            "periodSeconds": {
              "default": 10,
              "description": "Frequency of readiness probes.",
              "title": "periodSeconds",
              "type": "integer"
            },
            "timeoutSeconds": {
              "default": 2,
              "description": "Timeout for readiness probe.",
              "title": "timeoutSeconds",
              "type": "integer"
            }
          },
          "required": [
            "enabled",
            "httpGet",
            "initialDelaySeconds",
            "periodSeconds",
            "timeoutSeconds",
            "failureThreshold"
